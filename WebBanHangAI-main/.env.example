DJANGO_SECRET_KEY=change-this-to-a-long-random-string
DJANGO_DEBUG=True
DJANGO_ALLOWED_HOSTS=127.0.0.1,localhost
CORS_ALLOWED_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

# Backend connects to SQL Server running in Docker.
DATABASE_ENGINE=mssql

# False = SQL login (Docker SQL Server). True = Windows auth (local SQL Express).
SQLSERVER_TRUSTED_CONNECTION=False

SQLSERVER_DATABASE=FashionShopDB
SQLSERVER_USER=sa
SQLSERVER_PASSWORD=ChangeMe123!
SQLSERVER_HOST=127.0.0.1
SQLSERVER_PORT=1433
SQLSERVER_DRIVER=ODBC Driver 17 for SQL Server
SQLSERVER_EXTRA_PARAMS=TrustServerCertificate=yes;

# Resend email API
RESEND_API_KEY=
RESEND_FROM_EMAIL=Fashion Shop <onboarding@resend.dev>
FRONTEND_PUBLIC_URL=http://127.0.0.1:5173
