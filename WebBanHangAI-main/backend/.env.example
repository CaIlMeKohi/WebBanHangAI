DJANGO_SECRET_KEY=change-this-to-a-long-random-string
DJANGO_DEBUG=True
DJANGO_ALLOWED_HOSTS=127.0.0.1,localhost
CORS_ALLOWED_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

# Backend connects to SQL Server running in Docker.
DATABASE_ENGINE=mssql

# False = SQL login (Docker SQL Server). True = Windows auth (local SQL Express).
SQLSERVER_TRUSTED_CONNECTION=False



SQLSERVER_DATABASE=FashionShopDB
SQLSERVER_USER=sa
SQLSERVER_PASSWORD=123456
SQLSERVER_HOST=127.0.0.1
SQLSERVER_PORT=14330
SQLSERVER_DRIVER=ODBC Driver 17 for SQL Server
SQLSERVER_EXTRA_PARAMS=TrustServerCertificate=yes;

# Gmail SMTP. Use a Google App Password, not the normal Gmail password.
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USE_TLS=True
EMAIL_HOST_USER=thanhkhoi271105@gmail.com
EMAIL_HOST_PASSWORD=
DEFAULT_FROM_EMAIL=Fashion Shop <thanhkhoi271105@gmail.com>
EMAIL_TIMEOUT=15
FRONTEND_PUBLIC_URL=http://127.0.0.1:5173
PAYMENT_PENDING_TIMEOUT_MINUTES=15
PAYMENT_WEBHOOK_SECRET=

# Cloudinary image upload
